{% comment %}
  ShareCart Pro — My Shared Carts (Legacy Account Page App Block)
  Merchants drag this block onto their customers/account page template
  via the theme editor. Shows a list of the customer's shared carts.
{% endcomment %}

{% if customer %}
<div
  id="sharecart-account-widget"
  data-customer-id="{{ customer.id }}"
  style="margin: 24px 0;"
></div>

<script src="{{ 'sharecart-account.js' | asset_url | append: '&v=2' }}" defer></script>
{% endif %}

{% schema %}
{
  "name": "Shared Carts Widget",
  "target": "section",
  "enabled_on": {
    "templates": ["customers/account"]
  },
  "settings": [
    {
      "type": "paragraph",
      "content": "Displays the customer's shared carts with options to copy, pause, or delete each one. Only visible to logged-in customers."
    }
  ]
}
{% endschema %}
